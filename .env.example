# Neon Postgres connection string (Settings → Connection string in the Neon dashboard)
DATABASE_URL=postgresql://user:password@your-endpoint.region.aws.neon.tech/dbname?sslmode=require

# Secret used to sign session cookies — use a long random string
SESSION_SECRET=change-me-to-a-long-random-string

# Port the server listens on (optional, defaults to 3000)
PORT=3000
