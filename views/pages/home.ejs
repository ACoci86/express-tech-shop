<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<main class="container py-5">
  <div
    id="heroCarousel"
    class="carousel slide mb-5 rounded-4 overflow-hidden shadow"
    data-bs-ride="carousel"
  >
    <div class="carousel-indicators">
      <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
      <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
      <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
    </div>

    <div class="carousel-inner">
      <div class="carousel-item active">
        <img
          src="https://images.unsplash.com/photo-1517336714731-489689fd1ca8?auto=format&fit=crop&w=1600&q=80"
          class="d-block w-100"
          style="height: 440px; object-fit: cover;"
          alt="Laptop on a clean desk"
        >
        <div class="carousel-caption d-none d-md-block">
          <h2 class="mb-2">Gear up your workspace</h2>
          <p class="lead mb-3">Modern tech accessories, ready to ship.</p>
          <a href="/products" class="btn btn-primary">Shop now <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
      </div>

      <div class="carousel-item">
        <img
          src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?auto=format&fit=crop&w=1600&q=80"
          class="d-block w-100"
          style="height: 440px; object-fit: cover;"
          alt="Headphones on a desk"
        >
        <div class="carousel-caption d-none d-md-block">
          <h2 class="mb-2">Sound &amp; audio</h2>
          <p class="lead mb-0">Headphones and speakers for focus and play.</p>
        </div>
      </div>

      <div class="carousel-item">
        <img
          src="https://images.unsplash.com/photo-1593508512255-86ab42a8e620?auto=format&fit=crop&w=1600&q=80"
          class="d-block w-100"
          style="height: 440px; object-fit: cover;"
          alt="Person using a VR headset"
        >
        <div class="carousel-caption d-none d-md-block">
          <h2 class="mb-2">Step into the future</h2>
          <p class="lead mb-0">Next-gen gadgets and immersive tech.</p>
        </div>
      </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Next</span>
    </button>
  </div>

  <% if (featured.length > 0) { %>
    <section class="mb-5">
      <div class="d-flex justify-content-between align-items-end flex-wrap gap-2 mb-4">
        <div>
          <h2 class="fw-bold mb-1">Featured products</h2>
          <p class="text-muted mb-0">A few favourites, fresh in the shop.</p>
        </div>
        <a href="/products" class="btn btn-outline-primary">View all <i class="bi bi-arrow-right ms-1"></i></a>
      </div>

      <div class="row g-4">
        <% featured.forEach((product) => { %>
          <div class="col-sm-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm product-card">
              <img src="<%= product.image_url %>" class="card-img-top product-img" alt="<%= product.name %>">

              <div class="card-body d-flex flex-column">
                <h5 class="card-title"><%= product.name %></h5>
                <p class="card-text fs-5 fw-semibold text-primary mb-2">€<%= product.price %></p>

                <% if (product.stock === 0) { %>
                  <span class="badge bg-secondary align-self-start mb-3"><i class="bi bi-x-circle me-1"></i>Out of stock</span>
                <% } else { %>
                  <span class="badge bg-success-subtle text-success-emphasis align-self-start mb-3"><i class="bi bi-check-circle me-1"></i>In stock</span>
                <% } %>

                <a href="/products/<%= product.id %>" class="btn btn-primary mt-auto">
                  View Product <i class="bi bi-arrow-right ms-1"></i>
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  <% } %>

  <section
    class="text-center text-light rounded-4 p-5 mb-2"
    style="background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);"
  >
    <h2 class="fw-bold mb-2">Everything for your setup</h2>
    <p class="lead mb-4 opacity-75 col-lg-7 mx-auto">
      Browse the full collection and find your next upgrade.
    </p>
    <a href="/products" class="btn btn-light btn-lg"><i class="bi bi-bag me-1"></i>Browse all products</a>
  </section>
</main>

<%- include("../partials/footer") %>
