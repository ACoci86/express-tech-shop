<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<main class="container py-5">
  <div class="alert alert-success border-0 shadow-sm d-flex align-items-center gap-3">
    <i class="bi bi-check-circle-fill fs-1 check-animate"></i>
    <div>
      <h1 class="h3 mb-1">Thank you for your order!</h1>
      <p class="mb-0">Your order has been placed successfully.</p>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body d-flex flex-wrap justify-content-between gap-3">
      <div>
        <div class="text-muted small">Order ID</div>
        <div class="fs-5 fw-semibold">#<%= order.id %></div>
      </div>
      <div class="text-md-end">
        <div class="text-muted small">Total</div>
        <div class="fs-5 fw-semibold text-primary">€<%= Number(order.total).toFixed(2) %></div>
      </div>
    </div>
  </div>

  <h2 class="h4 mb-3">Products ordered</h2>

  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Subtotal</th>
          </tr>
        </thead>

        <tbody>
          <% orderItems.forEach((item) => { %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-3">
                  <img
                    src="<%= item.image_url %>"
                    alt="<%= item.name %>"
                    style="width: 64px; height: 64px; object-fit: cover;"
                    class="rounded"
                  >

                  <strong><%= item.name %></strong>
                </div>
              </td>

              <td>€<%= item.price %></td>
              <td><%= item.quantity %></td>
              <td>€<%= (item.price * item.quantity).toFixed(2) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <a href="/products" class="btn btn-primary mt-4">
    <i class="bi bi-arrow-left me-1"></i>Back to products
  </a>
</main>

<%- include("../partials/footer") %>
