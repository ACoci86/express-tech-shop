<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<main class="container py-5">
  <div class="card border-0 shadow-sm overflow-hidden">
    <div class="row g-0">
      <div class="col-md-6">
        <img
          src="<%= product.image_url %>"
          alt="<%= product.name %>"
          class="img-fluid w-100 h-100"
          style="object-fit: cover; min-height: 320px;"
        >
      </div>

      <div class="col-md-6">
        <div class="card-body p-4 p-lg-5">
          <span class="badge bg-light text-dark mb-2"><%= product.category %></span>
          <h1 class="h2"><%= product.name %></h1>
          <p class="text-muted"><%= product.description %></p>
          <h3 class="text-primary mb-3">€<%= product.price %></h3>

          <% if (product.stock > 0) { %>
            <p class="text-success fw-semibold"><i class="bi bi-check-circle-fill me-1"></i>In stock (<%= product.stock %>)</p>

            <form method="POST" action="/cart/add/<%= product.id %>" class="d-inline">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-cart-plus me-1"></i>Add to Cart
              </button>
            </form>
          <% } else { %>
            <p><span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>Out of stock</span></p>

            <button type="button" class="btn btn-primary" disabled>
              <i class="bi bi-cart-plus me-1"></i>Add to Cart
            </button>
          <% } %>

          <a href="/products" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Products
          </a>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include("../partials/footer") %>
